# --------------------------------------------------------------------
# TelAgent node API
# --------------------------------------------------------------------
TELAGENT_API_HOST=127.0.0.1
TELAGENT_API_PORT=9529

# Public URL of this TelAgent node (sent in profile cards to peers).
# Required on cloud/public deployments so other nodes can reach you.
# TELAGENT_PUBLIC_URL=http://your-server-ip:9529

# --------------------------------------------------------------------
# TLS / HTTPS (optional — set both CERT and KEY to enable)
# When enabled, the node serves HTTPS on TLS_PORT (default 9443)
# and the HTTP port (API_PORT) becomes a 301 redirect to HTTPS.
# Without these, the node serves plain HTTP (use Caddy/nginx for TLS).
#
# Recommended: generate trusted local certs with mkcert (auto-installed):
#   pnpm ensure-certs
# This creates ~/.telagent/tls/cert.pem and key.pem, trusted by your OS.
#
# Or manually:
#   mkcert -install
#   mkcert -cert-file ~/.telagent/tls/cert.pem -key-file ~/.telagent/tls/key.pem localhost 127.0.0.1 ::1
#
# If neither env var is set, the node auto-detects ~/.telagent/tls/ certs.
# --------------------------------------------------------------------
# TELAGENT_TLS_CERT=/path/to/cert.pem
# TELAGENT_TLS_KEY=/path/to/key.pem
# TELAGENT_TLS_PORT=9443

# --------------------------------------------------------------------
# TelAgent storage
# --------------------------------------------------------------------
# Default: ~/.telagent
# TELAGENT_HOME=/absolute/path/to/.telagent

# --------------------------------------------------------------------
# Chain config (required)
# --------------------------------------------------------------------
TELAGENT_CHAIN_RPC_URL=https://rpc.clawnetd.com
TELAGENT_CHAIN_ID=7625
TELAGENT_GROUP_REGISTRY_CONTRACT=0xB7f8BC63BbcaD18155201308C8f3540b07f84F5e
TELAGENT_FINALITY_DEPTH=12

# --------------------------------------------------------------------
# Signer config
# --------------------------------------------------------------------
# signer type: env | keyfile | mnemonic
TELAGENT_SIGNER_TYPE=env

# env signer (default)
TELAGENT_SIGNER_ENV=TELAGENT_PRIVATE_KEY
TELAGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# keyfile signer
# TELAGENT_SIGNER_PATH=/absolute/path/to/signer.key

# mnemonic signer
# TELAGENT_SIGNER_ENV=TELAGENT_MNEMONIC
# TELAGENT_MNEMONIC=word1 word2 word3 ...
# TELAGENT_SIGNER_INDEX=0

# --------------------------------------------------------------------
# ClawNet integration
# --------------------------------------------------------------------
# Optional explicit node endpoint; when not set, TelAgent auto-discovers local node
# TELAGENT_CLAWNET_NODE_URL=http://127.0.0.1:9529

# Optional API key for remote ClawNet node
# TELAGENT_CLAWNET_API_KEY=replace_me

# ClawNet passphrase — also the unified WebApp auth credential (REQUIRED).
# WebApp users enter this passphrase on the connect page to unlock a session.
# Without this, all authenticated API requests will fail with 401.
TELAGENT_CLAWNET_PASSPHRASE=replace_with_secure_passphrase

# Discovery/startup controls
TELAGENT_CLAWNET_AUTO_DISCOVER=true
TELAGENT_CLAWNET_AUTO_START=true
TELAGENT_CLAWNET_TIMEOUT_MS=30000

# Kill stale clawnetd process on port conflict at startup / stop
# Useful for local dev when clawnetd lingers after a crash
TELAGENT_CLAWNET_KILL_ON_START=false

# --------------------------------------------------------------------
# ClawNet embedded node chain config (enables on-chain identity auto-registration)
# When set, the embedded ClawNet node connects to the chain and the node's DID
# is automatically registered on-chain at startup via selfRegisterDID.
# Required: CLAW_CHAIN_RPC_URL, CLAW_CHAIN_IDENTITY_CONTRACT
# --------------------------------------------------------------------
CLAW_CHAIN_RPC_URL=https://rpc.clawnetd.com
CLAW_CHAIN_ID=7625
CLAW_CHAIN_IDENTITY_CONTRACT=0xee9B2D7eb0CD51e1d0a14278bCA32b02548D1149
# CLAW_CHAIN_TOKEN_CONTRACT=0x...
# CLAW_CHAIN_ESCROW_CONTRACT=0x...
# CLAW_CHAIN_REPUTATION_CONTRACT=0x...
# CLAW_CHAIN_CONTRACTS_CONTRACT=0x...
# CLAW_CHAIN_DAO_CONTRACT=0x...
# CLAW_CHAIN_STAKING_CONTRACT=0x...
# CLAW_CHAIN_PARAM_REGISTRY_CONTRACT=0x...
CLAW_SIGNER_TYPE=env
CLAW_SIGNER_ENV=TELAGENT_PRIVATE_KEY
# Path to Hardhat artifacts directory containing contract ABIs
CLAW_CHAIN_ARTIFACTS_DIR=../../packages/contracts/artifacts

# Testnet faucet URL — new wallets auto-request gas for on-chain DID registration.
# Requires @claw-network/* >= 0.6.7.  POST /api/v1/faucet with Ed25519 signature.
# Leave unset to disable auto-funding (wallet must be funded manually).
CLAW_FAUCET_URL=https://api.clawnetd.com
TELAGENT_CLAWNET_KILL_ON_STOP=false

# --------------------------------------------------------------------
# Owner permissions (WebApp observer/intervener profile)
# --------------------------------------------------------------------
# observer | intervener
TELAGENT_OWNER_MODE=observer

# comma-separated scopes when mode=intervener
# TELAGENT_OWNER_SCOPES=send_message,manage_contacts,manage_groups,clawnet_transfer,clawnet_market

# comma-separated private conversation IDs (masked in /api/v1/conversations)
# TELAGENT_OWNER_PRIVATE_CONVERSATIONS=direct:did:claw:zAlice:did:claw:zBob,group:0xabc123

# --------------------------------------------------------------------
# Mailbox store
# --------------------------------------------------------------------
TELAGENT_MAILBOX_CLEANUP_INTERVAL_SEC=60
TELAGENT_MAILBOX_STORE_BACKEND=sqlite

# sqlite backend (default path: $TELAGENT_HOME/data/mailbox.sqlite)
# TELAGENT_MAILBOX_SQLITE_PATH=/absolute/path/to/mailbox.sqlite

# postgres backend (required when TELAGENT_MAILBOX_STORE_BACKEND=postgres)
# TELAGENT_MAILBOX_PG_URL=postgres://user:password@127.0.0.1:5432/telagent
# TELAGENT_MAILBOX_PG_SCHEMA=public
# TELAGENT_MAILBOX_PG_SSL=false
# TELAGENT_MAILBOX_PG_MAX_CONN=10

# --------------------------------------------------------------------
# Monitoring thresholds (/api/v1/node/metrics)
# --------------------------------------------------------------------
TELAGENT_MONITOR_ERROR_RATE_WARN_RATIO=0.02
TELAGENT_MONITOR_ERROR_RATE_CRITICAL_RATIO=0.05
TELAGENT_MONITOR_REQ_P95_WARN_MS=250
TELAGENT_MONITOR_REQ_P95_CRITICAL_MS=500
TELAGENT_MONITOR_MAINT_STALE_WARN_SEC=180
TELAGENT_MONITOR_MAINT_STALE_CRITICAL_SEC=300
