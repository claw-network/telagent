# --------------------------------------------------------------------
# TelAgent node API
# --------------------------------------------------------------------
TELAGENT_API_HOST=127.0.0.1
TELAGENT_API_PORT=9528

# --------------------------------------------------------------------
# TelAgent storage
# --------------------------------------------------------------------
# Default: ~/.telagent
# TELAGENT_HOME=/absolute/path/to/.telagent

# --------------------------------------------------------------------
# Chain config (required)
# --------------------------------------------------------------------
TELAGENT_CHAIN_RPC_URL=https://rpc.clawnetd.com
TELAGENT_CHAIN_ID=7625
TELAGENT_GROUP_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000000
TELAGENT_FINALITY_DEPTH=12

# --------------------------------------------------------------------
# Signer config
# --------------------------------------------------------------------
# signer type: env | keyfile | mnemonic
TELAGENT_SIGNER_TYPE=env

# env signer (default)
TELAGENT_SIGNER_ENV=TELAGENT_PRIVATE_KEY
TELAGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# keyfile signer
# TELAGENT_SIGNER_PATH=/absolute/path/to/signer.key

# mnemonic signer
# TELAGENT_SIGNER_ENV=TELAGENT_MNEMONIC
# TELAGENT_MNEMONIC=word1 word2 word3 ...
# TELAGENT_SIGNER_INDEX=0

# --------------------------------------------------------------------
# ClawNet integration
# --------------------------------------------------------------------
# Optional explicit node endpoint; when not set, TelAgent auto-discovers local node
# TELAGENT_CLAWNET_NODE_URL=http://127.0.0.1:9528

# Optional API key for remote ClawNet node
# TELAGENT_CLAWNET_API_KEY=replace_me

# Passphrase used to unlock ClawNet write operations
# Highest priority source for passphrase resolver
# TELAGENT_CLAWNET_PASSPHRASE=replace_with_secure_passphrase

# Discovery/startup controls
TELAGENT_CLAWNET_AUTO_DISCOVER=true
TELAGENT_CLAWNET_AUTO_START=true
TELAGENT_CLAWNET_TIMEOUT_MS=30000

# --------------------------------------------------------------------
# Mailbox store
# --------------------------------------------------------------------
TELAGENT_MAILBOX_CLEANUP_INTERVAL_SEC=60
TELAGENT_MAILBOX_STORE_BACKEND=sqlite

# sqlite backend (default path: $TELAGENT_HOME/data/mailbox.sqlite)
# TELAGENT_MAILBOX_SQLITE_PATH=/absolute/path/to/mailbox.sqlite

# postgres backend (required when TELAGENT_MAILBOX_STORE_BACKEND=postgres)
# TELAGENT_MAILBOX_PG_URL=postgres://user:password@127.0.0.1:5432/telagent
# TELAGENT_MAILBOX_PG_SCHEMA=public
# TELAGENT_MAILBOX_PG_SSL=false
# TELAGENT_MAILBOX_PG_MAX_CONN=10

# --------------------------------------------------------------------
# Federation
# --------------------------------------------------------------------
TELAGENT_FEDERATION_SELF_DOMAIN=node-a.tel

# Optional auth token for inbound federation calls
# TELAGENT_FEDERATION_AUTH_TOKEN=replace_with_shared_secret

# Optional comma-separated allowlist
# TELAGENT_FEDERATION_ALLOWED_DOMAINS=node-b.tel,node-c.tel

# Optional protocol negotiation settings
# TELAGENT_FEDERATION_PROTOCOL_VERSION=v1
# TELAGENT_FEDERATION_SUPPORTED_PROTOCOLS=v1,v2

TELAGENT_FEDERATION_ENVELOPE_RATE_LIMIT_PER_MIN=600
TELAGENT_FEDERATION_SYNC_RATE_LIMIT_PER_MIN=300
TELAGENT_FEDERATION_RECEIPT_RATE_LIMIT_PER_MIN=600

# Federation replay protection
TELAGENT_FEDERATION_REPLAY_BACKOFF_BASE_MS=1000
TELAGENT_FEDERATION_REPLAY_BACKOFF_MAX_MS=60000
TELAGENT_FEDERATION_REPLAY_CIRCUIT_BREAKER_FAIL_THRESHOLD=3
TELAGENT_FEDERATION_REPLAY_CIRCUIT_BREAKER_COOLDOWN_SEC=30

# Federation DLQ replay scheduler
TELAGENT_FEDERATION_DLQ_REPLAY_INTERVAL_SEC=60
TELAGENT_FEDERATION_DLQ_REPLAY_BATCH_SIZE=100
TELAGENT_FEDERATION_DLQ_REPLAY_STOP_ON_ERROR=false

# Optional key pinning (disabled | enforced | report-only)
# TELAGENT_FEDERATION_PINNING_MODE=disabled
# TELAGENT_FEDERATION_PINNING_CURRENT_KEYS=node-b.tel=node-b-key-v1|node-b-key-v0
# TELAGENT_FEDERATION_PINNING_NEXT_KEYS=node-b.tel=node-b-key-v2
# TELAGENT_FEDERATION_PINNING_CUTOVER_AT=2026-03-10T09:00:00Z

# --------------------------------------------------------------------
# Domain proof
# --------------------------------------------------------------------
TELAGENT_DOMAIN_PROOF_MODE=enforced
TELAGENT_DOMAIN_PROOF_CHALLENGE_TTL_SEC=86400
TELAGENT_DOMAIN_PROOF_ROTATE_BEFORE_EXPIRY_SEC=900
TELAGENT_DOMAIN_PROOF_HTTP_TIMEOUT_MS=5000

# --------------------------------------------------------------------
# Monitoring thresholds (/api/v1/node/metrics)
# --------------------------------------------------------------------
TELAGENT_MONITOR_ERROR_RATE_WARN_RATIO=0.02
TELAGENT_MONITOR_ERROR_RATE_CRITICAL_RATIO=0.05
TELAGENT_MONITOR_REQ_P95_WARN_MS=250
TELAGENT_MONITOR_REQ_P95_CRITICAL_MS=500
TELAGENT_MONITOR_MAINT_STALE_WARN_SEC=180
TELAGENT_MONITOR_MAINT_STALE_CRITICAL_SEC=300
TELAGENT_MONITOR_FED_DLQ_ERROR_BUDGET_RATIO=0.01
TELAGENT_MONITOR_FED_DLQ_BURN_RATE_WARN=2
TELAGENT_MONITOR_FED_DLQ_BURN_RATE_CRITICAL=5

# --------------------------------------------------------------------
# Removed variables (do not set these; startup will fail)
# --------------------------------------------------------------------
# TELAGENT_DATA_DIR
# TELAGENT_SELF_DID
# TELAGENT_IDENTITY_CONTRACT
# TELAGENT_TOKEN_CONTRACT
