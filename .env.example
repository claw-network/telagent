TELAGENT_API_HOST=127.0.0.1
TELAGENT_API_PORT=9528
TELAGENT_DATA_DIR=.telagent

TELAGENT_CHAIN_RPC_URL=https://rpc.clawnetd.com
TELAGENT_CHAIN_ID=7625

TELAGENT_IDENTITY_CONTRACT=0x42ac5e96EB43c1390e7BED6Fc7FcAfe1375972E9
TELAGENT_TOKEN_CONTRACT=0xd9046ef83f8c910e4c828a1F8bEDDcD618fE3A73
# Optional: only set when ClawRouter integration is enabled
# TELAGENT_ROUTER_CONTRACT=0x...
TELAGENT_GROUP_REGISTRY_CONTRACT=0x...

TELAGENT_SELF_DID=did:claw:z6MkExample
TELAGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
TELAGENT_SIGNER_TYPE=env
TELAGENT_SIGNER_ENV=TELAGENT_PRIVATE_KEY

TELAGENT_FINALITY_DEPTH=12
TELAGENT_MAILBOX_CLEANUP_INTERVAL_SEC=60
TELAGENT_MAILBOX_STORE_BACKEND=sqlite
# Optional (default): sqlite mailbox store path
# TELAGENT_MAILBOX_SQLITE_PATH=.telagent/mailbox.sqlite
# Optional when TELAGENT_MAILBOX_STORE_BACKEND=postgres
# TELAGENT_MAILBOX_PG_URL=postgres://user:password@127.0.0.1:5432/telagent
# TELAGENT_MAILBOX_PG_SCHEMA=public
# TELAGENT_MAILBOX_PG_SSL=false
# TELAGENT_MAILBOX_PG_MAX_CONN=10

TELAGENT_FEDERATION_SELF_DOMAIN=node-a.tel
# Optional: enable federation token auth when set
# TELAGENT_FEDERATION_AUTH_TOKEN=replace_with_shared_secret
# Optional: comma-separated allowlist; empty means allow all valid domains
# TELAGENT_FEDERATION_ALLOWED_DOMAINS=node-b.tel,node-c.tel
# Optional: self protocol version for federation compatibility negotiation
# TELAGENT_FEDERATION_PROTOCOL_VERSION=v1
# Optional: explicitly declare compatible inbound versions
# TELAGENT_FEDERATION_SUPPORTED_PROTOCOLS=v1,v2
TELAGENT_FEDERATION_ENVELOPE_RATE_LIMIT_PER_MIN=600
TELAGENT_FEDERATION_SYNC_RATE_LIMIT_PER_MIN=300
TELAGENT_FEDERATION_RECEIPT_RATE_LIMIT_PER_MIN=600
# Optional: federation source key pinning mode (disabled|enforced|report-only)
# TELAGENT_FEDERATION_PINNING_MODE=disabled
# Optional: current key fingerprints by domain (domain=key1|key2,domain2=key3)
# TELAGENT_FEDERATION_PINNING_CURRENT_KEYS=node-b.tel=node-b-key-v1|node-b-key-v0
# Optional: next key fingerprints by domain for staged rotation
# TELAGENT_FEDERATION_PINNING_NEXT_KEYS=node-b.tel=node-b-key-v2
# Optional: cutover timestamp (ISO8601 or unix seconds/ms)
# TELAGENT_FEDERATION_PINNING_CUTOVER_AT=2026-03-10T09:00:00Z

# DomainProof challenge and expiry rotation (Phase 11)
TELAGENT_DOMAIN_PROOF_MODE=enforced
TELAGENT_DOMAIN_PROOF_CHALLENGE_TTL_SEC=86400
TELAGENT_DOMAIN_PROOF_ROTATE_BEFORE_EXPIRY_SEC=900
TELAGENT_DOMAIN_PROOF_HTTP_TIMEOUT_MS=5000

# Monitoring / alert thresholds (used by /api/v1/node/metrics)
TELAGENT_MONITOR_ERROR_RATE_WARN_RATIO=0.02
TELAGENT_MONITOR_ERROR_RATE_CRITICAL_RATIO=0.05
TELAGENT_MONITOR_REQ_P95_WARN_MS=250
TELAGENT_MONITOR_REQ_P95_CRITICAL_MS=500
TELAGENT_MONITOR_MAINT_STALE_WARN_SEC=180
TELAGENT_MONITOR_MAINT_STALE_CRITICAL_SEC=300
