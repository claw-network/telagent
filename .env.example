TELAGENT_API_HOST=127.0.0.1
TELAGENT_API_PORT=9528
TELAGENT_DATA_DIR=.telagent

TELAGENT_CHAIN_RPC_URL=https://rpc.clawnetd.com
TELAGENT_CHAIN_ID=7625

TELAGENT_IDENTITY_CONTRACT=0x42ac5e96EB43c1390e7BED6Fc7FcAfe1375972E9
TELAGENT_TOKEN_CONTRACT=0xd9046ef83f8c910e4c828a1F8bEDDcD618fE3A73
# Optional: only set when ClawRouter integration is enabled
# TELAGENT_ROUTER_CONTRACT=0x...
TELAGENT_GROUP_REGISTRY_CONTRACT=0x...

TELAGENT_SELF_DID=did:claw:z6MkExample
TELAGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
TELAGENT_SIGNER_TYPE=env
TELAGENT_SIGNER_ENV=TELAGENT_PRIVATE_KEY

TELAGENT_FINALITY_DEPTH=12
TELAGENT_MAILBOX_CLEANUP_INTERVAL_SEC=60

TELAGENT_FEDERATION_SELF_DOMAIN=node-a.tel
# Optional: enable federation token auth when set
# TELAGENT_FEDERATION_AUTH_TOKEN=replace_with_shared_secret
# Optional: comma-separated allowlist; empty means allow all valid domains
# TELAGENT_FEDERATION_ALLOWED_DOMAINS=node-b.tel,node-c.tel
TELAGENT_FEDERATION_ENVELOPE_RATE_LIMIT_PER_MIN=600
TELAGENT_FEDERATION_SYNC_RATE_LIMIT_PER_MIN=300
TELAGENT_FEDERATION_RECEIPT_RATE_LIMIT_PER_MIN=600
